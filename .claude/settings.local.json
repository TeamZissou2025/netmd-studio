{
  "permissions": {
    "allow": [
      "Bash(node --version && pnpm --version 2>/dev/null || echo \"pnpm not found\")",
      "Bash(corepack --version 2>/dev/null; npm --version 2>/dev/null)",
      "Bash(corepack enable:*)",
      "Bash(npm install:*)",
      "Bash(npx pnpm@9.15.0 --version 2>&1)",
      "Bash(pnpm install:*)",
      "Bash(which node:*)",
      "Bash(export PATH=\"$HOME/.local/bin:/usr/bin:/bin:$PATH\" && pnpm install 2>&1)",
      "Bash(kill %1 2>/dev/null; pkill -f \"vite\" 2>/dev/null; echo \"done\")",
      "Bash(export PATH=\"$HOME/.local/bin:/usr/bin:/bin:$PATH\" && pnpm add -D -w turbo 2>&1)",
      "Bash(export PATH=\"$HOME/.local/bin:/usr/bin:/bin:$PATH\" && cat node_modules/tailwindcss/package.json 2>/dev/null | grep '\"version\"')",
      "Bash(export PATH=\"$HOME/.local/bin:/usr/bin:/bin:$PATH\" && pnpm turbo build --filter=@netmd-studio/web 2>&1)",
      "Bash(git init:*)",
      "Bash(git add:*)"
    ]
  }
}
